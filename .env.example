# Kopier denne fil til .env.local og udfyld værdierne

# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# Opret gratis projekt på https://neon.tech — vælg EU-region (Frankfurt)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ─── Auth (Better Auth) ─────────────────────────────────────────────────────
# Generér med: openssl rand -base64 32
BETTER_AUTH_SECRET="skift-denne-til-en-lang-tilfaeldig-streng"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Opret gratis konto på https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Tastatur Helten <noreply@tastaturhelten.dk>"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://spil.v-skole.dk"
NEXT_PUBLIC_APP_NAME="Tastatur Helten"

# ─── Contact ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL="info@mediamax.dk"
